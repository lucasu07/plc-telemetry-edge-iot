'------------VARIABLES--------------*)


PROGRAM PLC_PRG
VAR

    (*TIME*)
    plcTime : DT;
    timeDword : DWORD;

	(*SYNC TIME*)
    syncDword : DWORD;
    syncTime  : DT;
    setRtcOk  : BOOL;

	(* SERIAL *)
    hCom : UDINT := 0;
    buffer : STRING(20);
    written : UDINT;
    initDone : BOOL := FALSE;

	(* LED *)
	Blink : BOOL := FALSE;

    (* CONTROLE *)
	valor : INT := 0;
	strValor: STRING(20);
	counter : INT := 0;

	(* MODBUS TCP *)
	mbServer :IL_ModBusTCPServer;
	regData : ARRAY[0..29] OF WORD;
	bitData : ARRAY[0..0] OF BYTE;

	(* MONITORING *)
	mbError : BOOL;
	mbErrorID : ERROR_CODE;

	temperatura : REAL := 25.7;

	(*ENVIO: FLOAT*)
	fbTemp : FB_RealToWords;
	fbPress : FB_RealToWords;
	fbSpeed : FB_RealToWords;

	(*ENVIO: STRING*)
	texto : STRING(20) := 'HELLOWORLD_2678';

	fbString2 : FB_StringToWords2;
	i: INT;

	pByte0: POINTER TO BYTE;
	pByte1: POINTER TO BYTE;
	pByte2: POINTER TO BYTE;
	pByte3: POINTER TO BYTE;
	pByte4: POINTER TO BYTE;
	pByte5: POINTER TO BYTE;

	w0: WORD;
	w1: WORD;
	w2: WORD;
	w3: WORD;
	w4: WORD;
	w5: WORD;

	pressao : REAL := 4.3; (*bar*)
	velocidade : REAL := 2.234; (*mm/s*)

END_VAR

(*------------MAIN--------------*)

(*Abertura do serial*)
IF NOT initDone THEN
    hCom := SysComOpen(2);
    initDone := TRUE;
END_IF;

(*Abertura da porta*)

mbServer(
	Enable := TRUE,
	Port := 5502,

	BitData := ADR(bitData),
	SizeOfBitData := SIZEOF(bitData),


	RegisterData := ADR(regData),
	(*Determinar o tamanho da informação a ser enviada*)
	SizeOfRegisterData := SIZEOF(regData)

);

	(*abertura do contador de tempo*)
	
	counter := counter + 1;


IF counter >= 200 THEN

valor := valor + 1;
temperatura := temperatura + 1.1;
pressao := pressao + 0.1;
velocidade := velocidade + 0.001;

strValor:= INT_TO_STRING(valor);

    buffer := strValor;

	(*ENVIO: INT*)

	regData[0] := valor;

	Blink := NOT Blink;


	(*ENVIO: COUNTER*)
	regData[1] := counter;

	(*ENVIO: BOOLEAN*)
	IF Blink THEN
		regData[2] := 1;
	ELSE
		regData[2] := 0;
	END_IF;

	(*ENVIO: FLOAT OCUPA 2 WORDS CADA*)

	fbTemp(RealValue := temperatura);
	regData[3] := fbTemp.WordLow;
	regData[4] := fbTemp.WordHigh;

	fbPress(RealValue := pressao);
	regData[5] := fbPress.WordLow;
	regData[6] := fbPress.WordHigh;

	fbSpeed(RealValue := velocidade);
	regData[7] := fbSpeed.WordLow;
	regData[8] := fbSpeed.WordHigh;

	(*ENVIO: STRING *)

    (* STRING PACKING PIPELINE *)
    fbString2(TextValue := texto);

    (* Direct array-to-array assignment via loop to prevent block execution lag *)
    FOR i := 0 TO 9 DO
        regData[9 + i] := fbString2.WordArray[i];
    END_FOR;

	(*ENVIO: DATE*)

	(* 1. Get current RTC time from the PLC *)
	plcTime := SysRtcGetTime(TRUE);

	(* 2. Convert to a 32-bit integer (seconds since epoch) *)
	timeDword := DT_TO_DWORD(plcTime);
	
	(* 3. Split into two Modbus WORDs (Little-Endian format) *)
	regData[19] := DWORD_TO_WORD(timeDword AND 16#FFFF);       (* Low Word *)
	regData[20] := DWORD_TO_WORD(SHR(timeDword, 16));
	
	plcTime := SysRtcGetTime(TRUE);

	(*ENVIO: SERIAL*)

    SysComWrite(
        hCom,
        ADR(buffer),
        LEN(buffer),
        ADR(written)
    );


    counter := 0;

(*ELSE*)

(*Blink := FALSE;*)

END_IF;

(* Check if Python has written a new timestamp to registers 21 and 22 *)
IF regData[21] <> 0 OR regData[22] <> 0 THEN
    
    (* 1. Combine the Low Word [21] and High Word [22] into a 32-bit DWORD *)
    syncDword := SHL(WORD_TO_DWORD(regData[22]), 16) OR WORD_TO_DWORD(regData[21]);
    
    (* 2. Convert to Date/Time format *)
    syncTime := DWORD_TO_DT(syncDword);

    (* 3. Overwrite the PLC internal hardware clock *)
    setRtcOk := SysRtcSetTime(syncTime);
    
    (* 4. Clear the registers to acknowledge receipt and prevent continuous writing *)
    regData[21] := 0;
    regData[22] := 0;
    
END_IF;


Blink_HMI := Blink;
OutputBlink := Blink;


(*ENVIO: DEBUG*)

mbError := mbServer.Error;
mbErrorID := mbServer.ErrorID;