FUNCTION_BLOCK FB_StringToWords2
VAR_INPUT
    TextValue  : STRING(20);
END_VAR
VAR_OUTPUT
    WordArray  : ARRAY[0..9] OF WORD;
END_VAR
VAR
    LocalBytes : ARRAY[0..19] OF BYTE;
    i          : INT;
    idx        : INT;
END_VAR

(*-------CONTINUE-------*)

(* Clear destination array to eliminate residual data *)
SysMemSet(ADR(WordArray), 0, SIZEOF(WordArray));
SysMemSet(ADR(LocalBytes), 0, SIZEOF(LocalBytes));

(* Atomic memory copy of string characters directly to byte array *)
SysMemCpy(ADR(LocalBytes), ADR(TextValue), MIN(LEN(TextValue), 20));

(* Pack bytes into 16-bit WORD registers with Big-Endian formatting *)
idx := 0;
FOR i := 0 TO 9 DO
    WordArray[i] := SHL(BYTE_TO_WORD(LocalBytes[idx]), 8) OR BYTE_TO_WORD(LocalBytes[idx + 1]);
    idx := idx + 2;
END_FOR;


